{
  "name": "prueba_evaluacion_pqr",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm run start:dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "db:up": "docker compose up -d db",
    "mail:up": "docker compose up -d mailpit",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "mail:logs": "docker compose logs -f mailpit",
    "db:seed": "npm run db:seed --prefix backend",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "npm run build --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "npm run lint --prefix backend",
    "lint:frontend": "npm run lint --prefix frontend"
  }
}
